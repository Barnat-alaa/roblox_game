# Normalise line endings so StyLua (Unix line endings) and CI agree on Windows.
* text=auto eol=lf

*.luau text eol=lf
*.lua  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml  text eol=lf

# Binary Roblox / image assets
*.rbxl  binary
*.rbxlx binary
*.rbxm  binary
*.rbxmx binary
*.png   binary
*.jpg   binary
*.ogg   binary
*.fbx   binary
*.blend binary
