--!strict
return function()
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	local Progression = require(ReplicatedStorage.Shared.Config.Progression)

	describe("Progression.levelForXp", function()
		it("starts at level 1", function()
			expect(Progression.levelForXp(0)).to.equal(1)
		end)
		it("levels up exactly at a threshold", function()
			expect(Progression.levelForXp(59)).to.equal(1)
			expect(Progression.levelForXp(60)).to.equal(2)
		end)
		it("caps at the max level", function()
			expect(Progression.levelForXp(9_999_999)).to.equal(Progression.maxLevel)
		end)
	end)

	describe("Progression.starsForReputation", function()
		it("has zero stars with no reputation", function()
			expect(Progression.starsForReputation(0)).to.equal(0)
		end)
		it("awards the first star at the threshold", function()
			expect(Progression.starsForReputation(50)).to.equal(1)
			expect(Progression.starsForReputation(49)).to.equal(0)
		end)
		it("awards five stars at the top", function()
			expect(Progression.starsForReputation(4000)).to.equal(5)
		end)
	end)
end
