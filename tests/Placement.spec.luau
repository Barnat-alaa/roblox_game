--!strict
return function()
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	local Grid = require(ReplicatedStorage.Shared.Utilities.Grid)

	describe("Grid.footprintSize", function()
		it("keeps dimensions on even rotations", function()
			local w, d = Grid.footprintSize(2, 1, 0)
			expect(w).to.equal(2)
			expect(d).to.equal(1)
		end)
		it("swaps dimensions on odd rotations", function()
			local w, d = Grid.footprintSize(2, 1, 1)
			expect(w).to.equal(1)
			expect(d).to.equal(2)
		end)
	end)

	describe("Grid.inBounds", function()
		it("accepts a footprint inside the plot", function()
			expect(Grid.inBounds(0, 0, 1, 1, 0)).to.equal(true)
		end)
		it("rejects negative coordinates", function()
			expect(Grid.inBounds(-1, 0, 1, 1, 0)).to.equal(false)
		end)
		it("rejects a footprint that runs off the far edge", function()
			expect(Grid.inBounds(Grid.PLOT_WIDTH - 1, 0, 2, 1, 0)).to.equal(false)
		end)
		it("accounts for rotation when checking the edge", function()
			-- a 1x2 piece at the bottom edge fits until rotated to 2x1
			expect(Grid.inBounds(Grid.PLOT_WIDTH - 1, 0, 1, 2, 0)).to.equal(true)
			expect(Grid.inBounds(Grid.PLOT_WIDTH - 1, 0, 1, 2, 1)).to.equal(false)
		end)
	end)

	describe("Grid.rectsOverlap", function()
		it("detects overlapping rectangles", function()
			expect(Grid.rectsOverlap(0, 0, 2, 2, 1, 1, 2, 2)).to.equal(true)
		end)
		it("treats edge-adjacent rectangles as non-overlapping", function()
			expect(Grid.rectsOverlap(0, 0, 1, 1, 1, 0, 1, 1)).to.equal(false)
		end)
	end)

	describe("Grid.occupiedCells", function()
		it("lists every cell in the footprint", function()
			expect(#Grid.occupiedCells(0, 0, 2, 2, 0)).to.equal(4)
			expect(#Grid.occupiedCells(3, 3, 3, 1, 0)).to.equal(3)
		end)
	end)
end
