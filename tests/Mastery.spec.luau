--!strict
return function()
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	local Mastery = require(ReplicatedStorage.Shared.Utilities.Mastery)

	local THRESHOLDS = { 5, 15, 40, 100 }

	describe("Mastery.levelFor", function()
		it("starts at zero stars", function()
			expect(Mastery.levelFor(THRESHOLDS, 0)).to.equal(0)
			expect(Mastery.levelFor(THRESHOLDS, 4)).to.equal(0)
		end)
		it("awards stars exactly at thresholds", function()
			expect(Mastery.levelFor(THRESHOLDS, 5)).to.equal(1)
			expect(Mastery.levelFor(THRESHOLDS, 14)).to.equal(1)
			expect(Mastery.levelFor(THRESHOLDS, 15)).to.equal(2)
			expect(Mastery.levelFor(THRESHOLDS, 40)).to.equal(3)
			expect(Mastery.levelFor(THRESHOLDS, 100)).to.equal(4)
		end)
		it("caps at the threshold count", function()
			expect(Mastery.levelFor(THRESHOLDS, 99999)).to.equal(4)
		end)
	end)

	describe("Mastery effects", function()
		it("reduces cook time per star", function()
			expect(Mastery.cookTime(100, 0, 0.05)).to.equal(100)
			expect(Mastery.cookTime(100, 2, 0.05)).to.equal(90)
			expect(Mastery.cookTime(100, 4, 0.05)).to.equal(80)
		end)
		it("never drops cook time below the floor", function()
			expect(Mastery.cookTime(6, 4, 0.05)).to.equal(5)
		end)
		it("reduces batch cost per star with a floor of one", function()
			expect(Mastery.batchCost(12, 0, 0.05)).to.equal(12)
			expect(Mastery.batchCost(12, 4, 0.05)).to.equal(9)
			expect(Mastery.batchCost(1, 4, 0.05)).to.equal(1)
		end)
		it("adds a bonus serving from the configured star", function()
			expect(Mastery.servings(12, 1, 2)).to.equal(12)
			expect(Mastery.servings(12, 2, 2)).to.equal(13)
		end)
		it("boosts the fresh bonus only at the top star", function()
			expect(Mastery.freshMult(3, 4, 1.5)).to.equal(1)
			expect(Mastery.freshMult(4, 4, 1.5)).to.equal(1.5)
		end)
	end)
end
